# Proxies for required interfaces
Proxies.CameraRGBDSimple = "camerargbdsimple:tcp -h localhost -p 0"
Proxies.Lidar3D = "lidar3d:tcp -h localhost -p 0"


# --- Common Agent Data ---
Agent.id = 0 # Change id
Agent.name = "robot_concept"

# --- Single Instance Configuration ---
# Use this if you only have one graph.
Agent.configFile = ""
Agent.domain = 0
Agent.tree = true
Agent.graph = true
Agent.2d = true
Agent.3d = true

# --- Multiple Instance Template ---
# If you define sub-instances, the single instance config above will be ignored.
# Agent.instance_name.configFile = ""
# Agent.instance_name.domain = 1
# Agent.instance_name.tree = true
# Agent.instance_name.graph = true
# Agent.instance_name.2d = true
# Agent.instance_name.3d = true

Period.Compute = 100
Period.Emergency = 500

# YOLO segmentation detector
Yolo.model_path  = "yolo26l-seg.onnx"
Yolo.conf_thresh = 0.25
Yolo.iou_thresh  = 0.45
Yolo.use_gpu     = True
Yolo.use_trt     = False

Component.Debug.Verbose = true

Ice.Warn.Connections = "0"
Ice.Trace.Network = "0"
Ice.Trace.Protocol = "0"
Ice.MessageSizeMax = "20004800"
